#!/usr/bin/env python3
"""
Immunex (imn) - Unified Command-Line Interface

A single command for all MD trajectory analysis tasks.
No need for separate batch scripts - just specify the analysis type and data location.

Usage:
    imn batch tcr-rmsd --input-dirs /data --max-workers 8
    imn batch cdr-rmsf --input-dirs /data --max-workers 4
    imn batch docking-angles --input-dirs /data --stride 10

Philosophy:
    - Pipeline defines WHAT to compute (business logic)
    - TaskDiscovery finds WHERE the data is
    - BatchExecutor handles HOW to run in parallel
    - User specifies: analysis type + data location + workers
"""

import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent.parent))

import argparse
import logging
from typing import List, Optional
import pandas as pd

from immunex.core import TaskDiscovery, PipelineContext
from immunex.pipeline import (
    BatchExecutor,
    TCRRMSDPipeline,
    pHLARMSDPipeline,
    HLAAlphaRMSDPipeline,
    CDRRMSFPipeline
)
from immunex.pipeline.nodes import ChainIdentificationNode
from immunex.analysis.angles import DockingAngleAnalyzer
from immunex.analysis.trajectory.contact_number import ContactNumberCalculator
from immunex.analysis.trajectory.interface_rmsd import ContactInterfaceRMSDCalculator
from immunex.analysis.allostery import ContactCorrelationAnalyzer
import numpy as np

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger(__name__)


# ============================================================================
# Task Discovery Helpers
# ============================================================================

def discover_standard_tasks(input_dirs: List[str],
                            trajectory_pattern: str = "*_processed.xtc") -> List[PipelineContext]:
    """
    Standard task discovery for most analyses.

    Args:
        input_dirs: List of input directories
        trajectory_pattern: Glob pattern for trajectory files

    Returns:
        List of discovered tasks
    """
    discovery = TaskDiscovery()

    def standard_rule(task_dir: Path):
        """Find tasks with processed trajectories."""
        trajectory_files = list(task_dir.glob(trajectory_pattern))
        if not trajectory_files:
            trajectory_files = list(task_dir.glob("md_pbc.xtc"))
        if not trajectory_files:
            trajectory_files = list(task_dir.glob("md.xtc"))

        topology = task_dir / "md.tpr"
        pdb_file = task_dir / "md_converted.pdb"

        if trajectory_files and topology.exists() and pdb_file.exists():
            return {
                'topology': str(topology),
                'trajectory_raw': str(trajectory_files[0]),
                'structure_pdb': str(pdb_file),
                'task_dir': str(task_dir)
            }
        return None

    discovery.add_rule(standard_rule)

    all_tasks = []
    for input_dir in input_dirs:
        discovered = discovery.discover(
            base_directory=input_dir,
            structure_type="flat"
        )
        all_tasks.extend(discovered)

    logger.info(f"Discovered {len(all_tasks)} tasks")
    return all_tasks


# ============================================================================
# Analysis Commands
# ============================================================================

def cmd_tcr_rmsd(args) -> int:
    """Execute TCR RMSD batch analysis."""
    logger.info("=" * 80)
    logger.info("TCR RMSD Batch Analysis")
    logger.info("=" * 80)

    # Discover tasks
    tasks = discover_standard_tasks(args.input_dirs)
    if not tasks:
        logger.error("No tasks found!")
        return 1

    # Set output directories
    output_dir = Path(args.output_dir)
    for task in tasks:
        task.output_dir = str(output_dir / task.system_id)

    # Create and execute pipeline
    pipeline = TCRRMSDPipeline(use_anarci=not args.no_anarci)
    executor = BatchExecutor(max_workers=args.max_workers)
    results = executor.execute_pipeline(tasks, pipeline, show_progress=True)

    # Save summary
    output_dir.mkdir(parents=True, exist_ok=True)
    executor.save_summary(results, str(output_dir / "batch_summary.csv"))

    # Print summary
    summary = executor.summarize_results(results)
    logger.info(f"✓ Success: {summary['successful']}/{summary['total_tasks']} tasks")

    return 0 if summary['failed'] == 0 else 1


