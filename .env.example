# Immunex Reporter LLM Configuration

# Enable LLM-enhanced answers (default: false)
IMMUNEX_LLM_ENABLED=true

# LLM Provider: openai, anthropic (default: openai)
IMMUNEX_LLM_PROVIDER=openai

# Model name (optional, uses provider default if not set)
# OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
IMMUNEX_LLM_MODEL=gpt-4o-mini

# API Key (required if LLM enabled)
OPENAI_API_KEY=sk-your-key-here
# or
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Temperature (0.0-1.0, default: 0.3)
IMMUNEX_LLM_TEMPERATURE=0.3

# Max tokens (default: 800)
IMMUNEX_LLM_MAX_TOKENS=800
